# ── Supabase (REQUIRED — set in Vercel dashboard for cloud deploy) ──────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# ── Dashboard Auth (REQUIRED) ──────────────────────────────────────────
DASHBOARD_PIN=1234

# ── Local-only: Bot process management ─────────────────────────────────
# These are IGNORED on Vercel (no local filesystem or Python runtime).
# Only useful when running `npm run dev` on the same machine as the bot.
WEATHER_BOT_DIR=D:\DATA\Ibrahim\poly\weather_bot
PYTHON_EXECUTABLE=python
ENABLE_DASHBOARD_BOT_START=true
