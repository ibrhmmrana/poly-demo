# ── Supabase (REQUIRED) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_KEY=eyJhbGciOi...your-service-role-key

# ── Dashboard Auth (REQUIRED) ─────────────────────────────────────
DASHBOARD_PIN=1234

# ── Bot API (REQUIRED — used by n8n to trigger scans) ─────────────
BOT_API_KEY=your-secret-api-key-here

# ── Polymarket (REQUIRED for live trading, optional for paper) ────
POLYMARKET_PRIVATE_KEY=0x...your-wallet-private-key
