# Mode: "paper" or "live"
MODE=paper

# Polymarket wallet private key (64-hex, optional 0x prefix)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_CHAIN_ID=137

# Supabase (required)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...your-service-role-key

# Thresholds (optional overrides)
# MIN_EDGE_PERCENT=15
# MAX_POSITION_USD=10
# KELLY_FRACTION=0.25
# MAX_LIQUIDITY_TAKE=0.30
# MIN_HOURS_TO_RESOLUTION=2
# MAX_HOURS_TO_RESOLUTION=72
# DAILY_LOSS_LIMIT_USD=-20

# NWS API (provide a contact email as required by api.weather.gov)
NWS_USER_AGENT=YourAppName (your@email.com)

# Telegram (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
